<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Duta Terang LED</title>

<style>
body{
font-family:Arial;
background:#f5f5f5;
padding:20px;
}

h2{
color:#ff0000;
}

.card{
background:white;
padding:15px;
margin-bottom:15px;
border-radius:10px;
box-shadow:0 2px 5px rgba(0,0,0,0.1);
}

button{
background:#ff0000;
color:white;
padding:10px;
border:none;
border-radius:6px;
cursor:pointer;
}

.cart{
background:#fff3cd;
padding:15px;
border-radius:10px;
}

input{
width:100%;
padding:8px;
margin-top:5px;
}
</style>
</head>

<body>

<h2>DUTA TERANG LED</h2>

<div class="card">
<select id="produk">
<option value="5W|3000">5W - 3.000</option>
<option value="7W|3500">7W - 3.500</option>
<option value="9W|4000">9W - 4.000</option>
<option value="12W|6000">12W - 6.000</option>
<option value="15W|6600">15W - 6.600</option>
<option value="18W|8000">18W - 8.000</option>
<option value="24W|11000">24W - 11.000</option>
<option value="30W|14000">30W - 14.000</option>
<option value="40W|17000">40W - 17.000</option>
</select>

<label>Jumlah:</label>
<input type="number" id="jumlah" value="1">

<br><br>
<button onclick="tambah()">Tambah Keranjang</button>
</div>

<div class="cart">
<h3>Keranjang</h3>
<div id="list"></div>
<h3>Total: Rp <span id="total">0</span></h3>
</div>

<div class="card">
<label>Nama</label>
<input id="nama">

<label>Alamat</label>
<input id="alamat">

<br><br>
<button onclick="checkout()">Checkout WA</button>
</div>

<script>
let cart=[]
let total=0

function tambah(){
let p=document.getElementById("produk").value.split("|")
let nama=p[0]
let harga=parseInt(p[1])
let jumlah=parseInt(document.getElementById("jumlah").value)

cart.push({nama,harga,jumlah})
render()
}

function render(){
let html=""
total=0

cart.forEach(i=>{
html+=i.nama+" x"+i.jumlah+" = "+(i.harga*i.jumlah)+"<br>"
total+=i.harga*i.jumlah
})

document.getElementById("list").innerHTML=html
document.getElementById("total").innerText=total
}

function checkout(){
let nama=document.getElementById("nama").value
let alamat=document.getElementById("alamat").value

let pesan="Halo Duta Terang LED%0AOrder:%0A"

cart.forEach(i=>{
pesan+=i.nama+" x"+i.jumlah+"%0A"
})

pesan+="Total: "+total+"%0A"
pesan+="Nama: "+nama+"%0AAlamat: "+alamat

window.open("https://wa.me/6288224166270?text="+pesan)
}
</script>

</body>
</html>
